{
  "buildCommand": "pip install -r requirements.txt",
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    },
    {
      "src": "static/minipdf/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/minipdf/(.*)",
      "dest": "/static/minipdf/$1"
    },
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ]
}
