{
  "buildCommand": "cd frontend && npm install && npx vite build && cd .. && pip install -r requirements.txt",
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/static/dist-spa/assets/$1"
    },
    {
      "src": "/src/(.*)",
      "dest": "/static/dist-spa/src/$1"
    },
    {
      "src": "/vite.svg",
      "dest": "/static/dist-spa/vite.svg"
    },
    {
      "src": "/minipdf/(.*)",
      "dest": "app.py"
    },
    {
      "src": "/static/(.*)",
      "dest": "app.py"
    },
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ],
  "headers": [
    {
      "source": "/minipdf/_framework/(.*\\.wasm)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/wasm"
        }
      ]
    },
    {
      "source": "/minipdf/_framework/(.*\\.dll)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/octet-stream"
        }
      ]
    }
  ]
}