{
  "buildCommand": "pip install -r requirements.txt && curl -sL https://github.com/tailwindlabs/tailwindcss/releases/download/v4.0.17/tailwindcss-linux-x64 -o tailwindcss && chmod +x tailwindcss && ./tailwindcss -i static/src/input.css -o static/dist/output.css --minify",
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/minipdf/(.*)",
      "dest": "app.py"
    },
    {
      "src": "/static/(.*)",
      "dest": "app.py"
    },
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ],
  "headers": [
    {
      "source": "/minipdf/_framework/(.*\\.wasm)",
      "headers": [
        {"key": "Content-Type", "value": "application/wasm"}
      ]
    },
    {
      "source": "/minipdf/_framework/(.*\\.dll)",
      "headers": [
        {"key": "Content-Type", "value": "application/octet-stream"}
      ]
    }
  ]
}
